<nav class="navbar navbar-light bg-white border-bottom px-3 py-2">
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-sm btn-outline-secondary d-lg-none" type="button"
      data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar">
      <i class="bi bi-list fs-5"></i>
    </button>
    <span class="text-muted fw-medium"><%= title %></span>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="badge bg-success-subtle text-success border border-success-subtle">
      <i class="bi bi-circle-fill me-1" style="font-size:0.5rem"></i>Online
    </span>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div class="dropdown">
      <button class="btn btn-sm btn-light border" data-bs-toggle="dropdown">
        <i class="bi bi-person-circle me-1"></i>
        <%= currentUser.full_name || currentUser.username %>
        <span class="ms-1 badge
          <%= currentUser.role === 'admin' ? 'bg-danger-subtle text-danger' :
              currentUser.role === 'manager' ? 'bg-warning-subtle text-warning' :
              'bg-primary-subtle text-primary' %>">
          <%= currentUser.role === 'admin' ? 'Администратор' :
              currentUser.role === 'manager' ? 'Менеджер' : 'Кассир' %>
        </span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm">
        <li><span class="dropdown-item-text text-muted small">@<%= currentUser.username %></span></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Выйти</a></li>
      </ul>
    </div>
    <% } %>
  </div>
</nav>
