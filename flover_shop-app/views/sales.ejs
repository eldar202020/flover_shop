<%- include('partials/head') %>
<%- include('partials/sidebar') %>

<div class="main-content d-flex flex-column">
  <%- include('partials/navbar') %>

  <div class="container-fluid p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-1">Управление продажами</h2>
        <p class="text-muted mb-0">История чеков и оформление новых продаж</p>
      </div>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#saleModal">
        <i class="bi bi-plus-lg me-2"></i>Создать продажу
      </button>
    </div>

    <!-- Таблица истории продаж -->
    <div class="table-wrap">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>Дата</th>
              <th>Клиент</th>
              <th>Прайс-лист</th>
              <th class="text-end">Сумма</th>
              <th class="text-center">Скидка</th>
              <th class="text-center">Чек</th>
            </tr>
          </thead>
          <tbody>
            <% if (sales.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-2 d-block mb-2"></i>Продаж пока нет
              </td>
            </tr>
            <% } %>
            <% sales.forEach(sale => {
              const customer = customers.find(c => c.id === sale.id_customer);
              const priceList = priceLists.find(p => p.id === sale.id_price_list);
            %>
            <tr>
              <td><span class="badge bg-light text-dark border">#<%= sale.id %></span></td>
              <td><%= new Date(sale.sale_date).toLocaleDateString('ru-RU') %></td>
              <td>
                <div class="fw-medium"><%= customer ? customer.name : '—' %></div>
                <% if (customer && customer.phone) { %>
                <small class="text-muted"><%= customer.phone %></small>
                <% } %>
              </td>
              <td><span class="badge bg-secondary-subtle text-secondary border"><%= priceList ? priceList.name : '—' %></span></td>
              <td class="text-end fw-semibold"><%= Number(sale.total_amount).toLocaleString('ru') %> ₽</td>
              <td class="text-center">
                <% const disc = customer ? Number(customer.personal_discount || 0) : 0; %>
                <% if (disc > 0) { %>
                <span class="badge bg-success-subtle text-success border"><%= disc %>%</span>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </td>
              <td class="text-center">
                <button class="btn btn-sm btn-outline-secondary btn-receipt"
                        data-sale-id="<%= sale.id %>"
                        data-sale-date="<%= new Date(sale.sale_date).toLocaleDateString('ru-RU') %>"
                        data-customer="<%= customer ? customer.name : '—' %>"
                        data-total="<%= Number(sale.total_amount).toLocaleString('ru') %>">
                  <i class="bi bi-receipt me-1"></i>Чек
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     МОДАЛЬНОЕ ОКНО: Создание продажи
═══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="saleModal" tabindex="-1" aria-labelledby="saleModalLabel">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title" id="saleModalLabel">
          <i class="bi bi-receipt me-2 text-primary"></i>Новая продажа
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body pt-2">
        <form id="saleForm" novalidate>

          <!-- Клиент + Прайс-лист -->
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-medium">Клиент <span class="text-danger">*</span></label>
              <select class="form-select" id="selectCustomer" required>
                <option value="">Выберите клиента...</option>
                <% customers.forEach(c => { %>
                <option value="<%= c.id %>"
                        data-purchases="<%= c.personal_purchases || 0 %>"
                        data-discount="<%= c.personal_discount || 0 %>">
                  <%= c.name %> (<%= c.phone %>)
                </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Прайс-лист <span class="text-danger">*</span></label>
              <select class="form-select" id="selectPriceList" required>
                <option value="">Выберите прайс-лист...</option>
                <% priceLists.forEach(pl => { %>
                <option value="<%= pl.id %>"><%= pl.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <!-- Блок скидки лояльности -->
          <div id="discountAlert" class="alert alert-success d-flex align-items-center gap-2 py-2 d-none mb-3">
            <i class="bi bi-patch-check-fill text-success"></i>
            <span id="discountText"></span>
          </div>

          <hr class="my-3">

          <!-- Список позиций товаров -->
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0 fw-semibold">Состав чека</h6>
            <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddRow">
              <i class="bi bi-plus me-1"></i>Добавить позицию
            </button>
          </div>

          <div id="saleItemsContainer">
            <!-- Строки товаров добавляются динамически -->
            <div class="text-muted small text-center py-3" id="emptyItemsMsg">
              <i class="bi bi-basket me-1"></i>Нажмите «Добавить позицию»
            </div>
          </div>

          <hr class="my-3">

          <!-- Итоговая сумма -->
          <div class="d-flex flex-column align-items-end gap-1">
            <div class="text-muted small">
              Промежуточный итог: <strong id="subtotalDisplay">0,00 ₽</strong>
            </div>
            <div class="d-flex align-items-center gap-2">
              <span class="text-muted">Скидка:</span>
              <span class="text-success fw-semibold" id="discountAmountDisplay">0,00 ₽</span>
            </div>
            <div class="h4 mb-0">
              Итого: <span class="text-primary fw-bold" id="totalDisplay">0,00 ₽</span>
            </div>
          </div>

        </form>
      </div>

      <div class="modal-footer border-top-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Отмена</button>
        <button type="button" class="btn btn-primary" id="btnSubmitSale">
          <i class="bi bi-check-lg me-1"></i>Оформить продажу
        </button>
      </div>

    </div>
  </div>
</div>

<!-- Данные для JS (передаём массив товаров с сервера) -->
<!-- Модал: Ошибка остатка -->
<div class="modal fade" id="stockErrorModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0">
      <div class="modal-body text-center p-4">
        <div class="mb-3">
          <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3.5rem"></i>
        </div>
        <h5 class="fw-bold">Недостаточно товара на складе</h5>
        <p class="text-muted mb-3" id="stockErrorMsg">—</p>
        <div class="d-flex justify-content-center gap-3">
          <div class="text-center">
            <div class="h4 text-danger mb-0" id="stockErrorRequested">0</div>
            <small class="text-muted">Запрашивается</small>
          </div>
          <div class="text-muted d-flex align-items-center fs-4">›</div>
          <div class="text-center">
            <div class="h4 text-success mb-0" id="stockErrorAvailable">0</div>
            <small class="text-muted">В наличии</small>
          </div>
        </div>
        <button type="button" class="btn btn-primary mt-4 px-4" data-bs-dismiss="modal">
          Понятно
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     МОДАЛЬНОЕ ОКНО: Просмотр чека
═══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="receiptModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title">
          <i class="bi bi-receipt me-2 text-primary"></i>
          Чек <span id="receiptSaleId" class="text-muted fw-normal"></span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <!-- Шапка чека -->
        <div class="d-flex justify-content-between text-muted small mb-3 pb-2 border-bottom">
          <span><i class="bi bi-calendar3 me-1"></i><span id="receiptDate"></span></span>
          <span><i class="bi bi-person me-1"></i><span id="receiptCustomer"></span></span>
        </div>

        <!-- Список товаров -->
        <div id="receiptItemsLoader" class="text-center py-3">
          <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
          <div class="small text-muted mt-1">Загрузка...</div>
        </div>
        <table class="table table-sm align-middle mb-0 d-none" id="receiptItemsTable">
          <thead class="table-light">
            <tr>
              <th>Товар</th>
              <th class="text-center">Кол-во</th>
              <th class="text-end">Цена</th>
              <th class="text-end">Итого</th>
            </tr>
          </thead>
          <tbody id="receiptItemsBody"></tbody>
        </table>
        <div class="text-muted text-center py-3 d-none" id="receiptNoItems">
          <i class="bi bi-inbox me-1"></i>Позиции не найдены
        </div>

        <!-- Итог -->
        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
          <span class="fw-semibold">Итого:</span>
          <span class="h5 mb-0 text-primary fw-bold" id="receiptTotal"></span>
        </div>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Закрыть</button>
        <button type="button" class="btn btn-outline-primary" id="btnDownloadPDF">
          <i class="bi bi-file-earmark-pdf me-1"></i>Скачать PDF
        </button>
        <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
          <i class="bi bi-printer me-1"></i>Печать
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Библиотека для PDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<%- include('partials/footer') %>
